{
  "version": 2,
  "functions": {
    "api/**/*.js": {
      "memory": 1024,
      "maxDuration": 10
    }
  },
  "rewrites": [
    {
      "source": "/poster/:title",
      "destination": "/api/poster/:title"
    },
    {
      "source": "/poster-img/:title.jpg",
      "destination": "/api/poster-img/:title"
    }
  ]
}
